# Vendure Remix Storefront - Environment Variables Template
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control

# ============================================
# REQUIRED - Production
# ============================================

# Vendure API URL
# Your Vendure server's shop API endpoint
VENDURE_API_URL=https://readonlydemo.vendure.io/shop-api

# Session Secret (REQUIRED IN PRODUCTION)
# Generate a strong random secret with: openssl rand -base64 32
# Must be at least 32 characters long
SESSION_SECRET=change-this-in-production-min-32-chars

# Node Environment
# Set to 'production' for production deployments
NODE_ENV=development

# ============================================
# OPTIONAL - Payment Gateways
# ============================================

# Stripe Publishable Key
# Only required if using Stripe payment gateway
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================
# OPTIONAL - Monitoring & Analytics
# ============================================

# Google Analytics Measurement ID
# Only required if using Google Analytics
# Get from: https://analytics.google.com/
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN for Error Monitoring
# Only required if using Sentry for error tracking
# Get from: https://sentry.io/
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# OPTIONAL - Application Configuration
# ============================================

# Application URL
# Used for generating absolute URLs (e.g., in emails, sitemaps)
# APP_URL=https://your-storefront-domain.com

# ============================================
# Platform-Specific Variables
# ============================================

# For Cloudflare Pages deployments
# CF_PAGES=1

# For Netlify deployments
# NETLIFY=1
