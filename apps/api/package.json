{
  "name": "@hunter-irrigation/api",
  "version": "1.0.0",
  "private": true,
  "description": "Vendure headless commerce API",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "migration:create": "ts-node -r tsconfig-paths/register src/migrate.ts create",
    "migration:run": "ts-node -r tsconfig-paths/register src/migrate.ts run",
    "migration:revert": "ts-node -r tsconfig-paths/register src/migrate.ts revert",
    "seed": "ts-node -r tsconfig-paths/register src/seed.ts",
    "update-admin": "ts-node -r tsconfig-paths/register src/update-admin.ts",
    "update-admin-fixed": "ts-node -r tsconfig-paths/register src/update-admin-fixed.ts",
    "fix-admin": "ts-node -r tsconfig-paths/register src/fix-admin-properly.ts",
    "create-or-update-admin": "ts-node -r tsconfig-paths/register src/create-or-update-admin.ts",
    "setup-mfa": "ts-node -r tsconfig-paths/register src/setup-totp-mfa.ts",
    "import-woocommerce": "ts-node -r tsconfig-paths/register src/scripts/woocommerce-import/index.ts",
    "link-s3-images": "ts-node -r tsconfig-paths/register src/scripts/link-s3-images-to-products.ts",
    "fix-asset-storage": "ts-node -r tsconfig-paths/register src/scripts/fix-asset-storage.ts",
    "check-asset-storage": "ts-node -r tsconfig-paths/register src/scripts/check-asset-storage.ts",
    "fix-asset-storage-raw": "ts-node -r tsconfig-paths/register src/scripts/fix-asset-storage-raw-sql.ts",
    "sync-tax-rates": "ts-node -r tsconfig-paths/register src/scripts/sync-tax-rates.ts",
    "sync-tax-rates-email": "ts-node -r tsconfig-paths/register src/scripts/sync-tax-rates-with-email.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.490.0",
    "@vendure/admin-ui-plugin": "^2.3.3",
    "@vendure/asset-server-plugin": "^2.3.3",
    "@vendure/core": "^2.3.3",
    "@vendure/email-plugin": "^2.3.3",
    "@vendure/job-queue-plugin": "^2.3.3",
    "@vendure/payments-plugin": "^2.3.3",
    "apollo-server-express": "^3.12.1",
    "csv-parse": "^5.6.0",
    "express": "^4.18.2",
    "graphql": "16.6.0",
    "node-fetch": "2",
    "otplib": "^12.0.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "reflect-metadata": "^0.1.14",
    "type-graphql": "^1.1.1",
    "typeorm": "0.3.17"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.4",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "nodemailer": "^7.0.11",
    "ssh2": "^1.17.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "graphql": "16.6.0"
  }
}
